return {
  "yetone/avante.nvim",
  event = "VeryLazy",
  version = false,
  build = "make",
  opts = {
    provider = "ollama",
    providers = {
      ollama = {
        model = "qwen2.5-coder:7b",
        is_env_set = function()
          return require("avante.providers.ollama").check_endpoint_alive()
